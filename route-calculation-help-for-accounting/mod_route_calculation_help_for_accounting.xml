<?xml version="1.0" encoding="utf-8"?>
<extension type="module" version="6.0" client="site" method="upgrade">
  <name>MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING</name>
  <author>Darko Fatur</author>
  <creationDate>2026-07-14</creationDate>
  <copyright>Copyright (C) 2026 topoweryou.com</copyright>
  <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
  <authorEmail>info@topoweryou.com</authorEmail>
  <authorUrl>https://topoweryou.com</authorUrl>
  <version>1.3.0</version>
  <description>MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_XML_DESCRIPTION</description>
  <updateservers>
    <server type="extension" priority="1" name="Route Calculation Help for Accounting Updates">https://builder.topoweryou.com/routecalculationhelp/files/routecalculationhelp/updates/route-calculation-help-for-accounting.xml</server>
  </updateservers>
  <files>
    <filename module="mod_route_calculation_help_for_accounting">mod_route_calculation_help_for_accounting.php</filename>
    <filename>helper.php</filename>
    <filename>index.html</filename>
    <filename>LICENSE.txt</filename>
    <folder>services</folder>
    <folder>sql</folder>
    <folder>src</folder>
    <folder>tmpl</folder>
    <folder>media</folder>
    <folder>forms</folder>
  </files>
  <languages folder="language">
    <language tag="en-GB">en-GB/en-GB.mod_route_calculation_help_for_accounting.ini</language>
    <language tag="en-GB">en-GB/en-GB.mod_route_calculation_help_for_accounting.sys.ini</language>
    <language tag="sl-SI">sl-SI/sl-SI.mod_route_calculation_help_for_accounting.ini</language>
    <language tag="sl-SI">sl-SI/sl-SI.mod_route_calculation_help_for_accounting.sys.ini</language>
  </languages>
  <namespace path="src">Joomla\Module\RouteCalculationHelpForAccounting</namespace>
  <install>
    <sql>
      <file driver="mysql" charset="utf8">sql/install/mysql/install.sql</file>
    </sql>
  </install>
  <uninstall>
    <sql>
      <file driver="mysql" charset="utf8">sql/uninstall/mysql/uninstall.sql</file>
    </sql>
  </uninstall>
  <config>
    <fields name="params">
      <fieldset name="basic" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELDSET_OPTIONS">
        <field
          name="google_maps_api_key"
          type="password"
          label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_GOOGLE_MAPS_API_KEY_LABEL"
          description="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_GOOGLE_MAPS_API_KEY_DESC"
          filter="raw"
        />
        <field
          name="base_country"
          type="list"
          label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_BASE_COUNTRY_LABEL"
          description="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_BASE_COUNTRY_DESC"
          default="SI"
        >
          <option value="SI">MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_CALCULATOR_SLOVENIA</option>
          <option value="IT">MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_CALCULATOR_ITALY</option>
          <option value="HR">MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_CALCULATOR_CROATIA</option>
          <option value="AT">MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_CALCULATOR_AUSTRIA</option>
          <option value="DE">MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_CALCULATOR_GERMANY</option>
          <option value="HU">MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_CALCULATOR_HUNGARY</option>
        </field>
        <field type="spacer" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_SPACER_COMPANY_DETAILS" />
        <field name="company_name" type="text" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_COMPANY_NAME_LABEL" default="Example Transfer Ltd." />
        <field name="company_address" type="text" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_COMPANY_ADDRESS_LABEL" default="Example Street 1" />
        <field name="company_postcode_city" type="text" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_COMPANY_POSTCODE_CITY_LABEL" default="1000 Example City" />
        <field name="company_tax_number" type="text" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_COMPANY_TAX_NUMBER_LABEL" default="EX12345678" />
        <field name="company_registration_number" type="text" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_COMPANY_REGISTRATION_NUMBER_LABEL" default="1234567890" />
        <field name="company_iban" type="text" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_COMPANY_IBAN_LABEL" default="EX001234567890123456" />
        <field name="company_email" type="email" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_COMPANY_EMAIL_LABEL" default="office@example.com" />
        <field name="company_phone" type="text" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_COMPANY_PHONE_LABEL" default="+386 00 000 000" />
        <field name="company_issue_city" type="text" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_COMPANY_ISSUE_CITY_LABEL" default="Example City" />
        <field
          name="pdf_signature_image_url"
          type="text"
          label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_PDF_SIGNATURE_IMAGE_URL_LABEL"
          description="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_PDF_SIGNATURE_IMAGE_URL_DESC"
          default="podpis-transparent.png"
          filter="string"
        />
      </fieldset>
      <fieldset name="minimax" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELDSET_MINIMAX">
        <field name="minimax_receivable_account" type="text" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_MINIMAX_RECEIVABLE_ACCOUNT_LABEL" default="" />
        <field name="minimax_base_country_standard_vat_account" type="text" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_MINIMAX_BASE_COUNTRY_STANDARD_VAT_ACCOUNT_LABEL" description="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_MINIMAX_BASE_COUNTRY_STANDARD_VAT_ACCOUNT_DESC" default="" />
        <field name="minimax_default_foreign_revenue_account" type="text" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_MINIMAX_DEFAULT_FOREIGN_REVENUE_ACCOUNT_LABEL" description="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_MINIMAX_DEFAULT_FOREIGN_REVENUE_ACCOUNT_DESC" default="" />
        <field
          name="minimax_country_accounts"
          type="subform"
          label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_MINIMAX_COUNTRY_ACCOUNTS_LABEL"
          description="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_MINIMAX_COUNTRY_ACCOUNTS_DESC"
          formsource="modules/mod_route_calculation_help_for_accounting/forms/minimax_account.xml"
          multiple="true"
          layout="joomla.form.field.subform.repeatable"
          buttons="add,remove,move"
          validate="Subform"
        />
      </fieldset>
      <fieldset name="countries" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELDSET_COUNTRIES">
        <field name="default_foreign_passenger_vat_rate" type="number" label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_DEFAULT_FOREIGN_PASSENGER_VAT_RATE_LABEL" description="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_DEFAULT_FOREIGN_PASSENGER_VAT_RATE_DESC" default="" step="0.1" min="0" />
        <field
          name="countries"
          type="subform"
          label="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_COUNTRIES_LABEL"
          description="MOD_ROUTE_CALCULATION_HELP_FOR_ACCOUNTING_FIELD_COUNTRIES_DESC"
          formsource="modules/mod_route_calculation_help_for_accounting/forms/country.xml"
          multiple="true"
          layout="joomla.form.field.subform.repeatable"
          buttons="add,remove,move"
          validate="Subform"
        />
      </fieldset>
    </fields>
  </config>
</extension>

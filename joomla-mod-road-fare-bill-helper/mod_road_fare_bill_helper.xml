  <authorUrl>https://topoweryou.com</authorUrl>
  <version>1.2.15</version>
  <description>MOD_ROAD_FARE_BILL_HELPER_XML_DESCRIPTION</description>
  <files>
    <filename module="mod_road_fare_bill_helper">mod_road_fare_bill_helper.php</filename>
    <filename>helper.php</filename>
    <filename>index.html</filename>
    <filename>LICENSE.txt</filename>
    <folder>services</folder>
    <folder>sql</folder>
    <folder>src</folder>
    <folder>tmpl</folder>
    <folder>media</folder>
    <folder>language</folder>
  </files>
  <namespace path="src">Joomla\Module\RoadFareBillHelper</namespace>
  <install>
    <sql>
      <file driver="mysql" charset="utf8">sql/install/mysql/install.sql</file>
    </sql>
  </install>
  <uninstall>
    <sql>
      <file driver="mysql" charset="utf8">sql/uninstall/mysql/uninstall.sql</file>
    </sql>
  </uninstall>
  <config>
    <fields name="params">
      <fieldset name="basic" label="MOD_ROAD_FARE_BILL_HELPER_FIELDSET_OPTIONS">
        <field
          name="google_maps_api_key"
          type="password"
          label="MOD_ROAD_FARE_BILL_HELPER_FIELD_GOOGLE_MAPS_API_KEY_LABEL"
          description="MOD_ROAD_FARE_BILL_HELPER_FIELD_GOOGLE_MAPS_API_KEY_DESC"
          filter="raw"
        />
        <field type="spacer" label="MOD_ROAD_FARE_BILL_HELPER_SPACER_COMPANY_DETAILS" />
        <field name="company_name" type="text" label="MOD_ROAD_FARE_BILL_HELPER_FIELD_COMPANY_NAME_LABEL" default="TUAM d.o.o." />
        <field name="company_address" type="text" label="MOD_ROAD_FARE_BILL_HELPER_FIELD_COMPANY_ADDRESS_LABEL" default="Vojkova ulica 15" />
        <field name="company_postcode_city" type="text" label="MOD_ROAD_FARE_BILL_HELPER_FIELD_COMPANY_POSTCODE_CITY_LABEL" default="5270 Ajdovscina" />
        <field name="company_tax_number" type="text" label="MOD_ROAD_FARE_BILL_HELPER_FIELD_COMPANY_TAX_NUMBER_LABEL" default="SI96392126" />
        <field name="company_registration_number" type="text" label="MOD_ROAD_FARE_BILL_HELPER_FIELD_COMPANY_REGISTRATION_NUMBER_LABEL" default="6127860000" />
        <field name="company_iban" type="text" label="MOD_ROAD_FARE_BILL_HELPER_FIELD_COMPANY_IBAN_LABEL" default="SI56101000050570266" />
        <field name="company_email" type="email" label="MOD_ROAD_FARE_BILL_HELPER_FIELD_COMPANY_EMAIL_LABEL" default="transfer@tuam.si" />
        <field name="company_phone" type="text" label="MOD_ROAD_FARE_BILL_HELPER_FIELD_COMPANY_PHONE_LABEL" default="+38640805763" />
        <field name="company_issue_city" type="text" label="MOD_ROAD_FARE_BILL_HELPER_FIELD_COMPANY_ISSUE_CITY_LABEL" default="Ajdovscina" />
        <field type="spacer" label="MOD_ROAD_FARE_BILL_HELPER_SPACER_REVENUE_ACCOUNTS" />
        <field name="revenue_account_slovenia" type="text" label="MOD_ROAD_FARE_BILL_HELPER_FIELD_REVENUE_ACCOUNT_SLOVENIA_LABEL" default="7601" />
        <field name="revenue_account_italy" type="text" label="MOD_ROAD_FARE_BILL_HELPER_FIELD_REVENUE_ACCOUNT_ITALY_LABEL" default="7602" />
        <field name="revenue_account_croatia" type="text" label="MOD_ROAD_FARE_BILL_HELPER_FIELD_REVENUE_ACCOUNT_CROATIA_LABEL" default="7603" />
        <field name="revenue_account_austria" type="text" label="MOD_ROAD_FARE_BILL_HELPER_FIELD_REVENUE_ACCOUNT_AUSTRIA_LABEL" default="7604" />
        <field name="revenue_account_germany" type="text" label="MOD_ROAD_FARE_BILL_HELPER_FIELD_REVENUE_ACCOUNT_GERMANY_LABEL" default="7605" />
      </fieldset>
    </fields>
  </config>
